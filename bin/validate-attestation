#!/usr/bin/env python3
"""Validate completion attestation against contract criteria.

Reads attestation JSONL from stdin, reads the last contract event from
the Era stream, and checks that every contract criterion appears in
the attestation with a valid status.
"""

import json
import subprocess
import sys


VALID_STATUSES = {"delivered", "dropped", "added"}


def read_events(stream):
    result = subprocess.run(
        ["era", "read", "--json", "--limit", "10000", stream],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"error: era read failed: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return json.loads(result.stdout) if result.stdout.strip() else []


def find_last_contract(events):
    for e in reversed(events):
        if e["event_type"].lower() == "contract":
            return e
    return None


def parse_jsonl(text, label):
    """Parse JSONL text into {"criteria": [...]} dict."""
    criteria = []
    metadata = {}
    for line in text.strip().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError as e:
            print(f"error: failed to parse {label} JSONL line: {e}", file=sys.stderr)
            print(f"  line: {line}", file=sys.stderr)
            sys.exit(1)
        if "name" in obj:
            criteria.append(obj)
        else:
            metadata.update(obj)
    result = dict(metadata)
    result["criteria"] = criteria
    return result


def validate(contract, attestation):
    contract_criteria = {c["name"] for c in contract.get("criteria", [])}
    attestation_map = {c["name"]: c for c in attestation.get("criteria", [])}

    errors = 0

    # Check every contract criterion is attested
    for name in sorted(contract_criteria):
        if name not in attestation_map:
            print(f"  MISSING: {name}", file=sys.stderr)
            errors += 1
        else:
            entry = attestation_map[name]
            status = entry.get("status", "")
            if status not in VALID_STATUSES:
                print(f"  INVALID STATUS: {name} -> '{status}'", file=sys.stderr)
                errors += 1

    # Report added criteria (informational)
    added = [
        c for c in attestation.get("criteria", [])
        if c["name"] not in contract_criteria
    ]
    for c in added:
        status = c.get("status", "")
        if status != "added":
            print(f"  WARNING: '{c['name']}' not in contract but status is '{status}', expected 'added'", file=sys.stderr)
            errors += 1
        else:
            print(f"  added: {c['name']}")

    return errors


def main():
    if len(sys.argv) < 2:
        print("usage: validate-attestation <stream>", file=sys.stderr)
        print("reads attestation JSONL from stdin", file=sys.stderr)
        sys.exit(1)

    stream = sys.argv[1]
    attestation_text = sys.stdin.read()

    # Parse attestation
    attestation = parse_jsonl(attestation_text, "attestation")

    # Read stream and find last contract
    events = read_events(stream)
    contract_event = find_last_contract(events)

    if not contract_event:
        print("info: no contract event found in stream, skipping validation")
        sys.exit(0)

    # Parse contract payload as JSONL
    contract = parse_jsonl(contract_event["payload"], "contract")

    # Validate
    errors = validate(contract, attestation)

    if errors > 0:
        print(f"\nwarning: {errors} attestation issue(s) found", file=sys.stderr)
        sys.exit(1)
    else:
        contract_count = len(contract.get("criteria", []))
        attestation_count = len(attestation.get("criteria", []))
        print(f"  attestation valid: {attestation_count} criteria ({contract_count} from contract)")


if __name__ == "__main__":
    main()
